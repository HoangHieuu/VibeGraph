{
  "name": "@vibedev/vibegraph",
  "version": "0.1.0",
  "description": "Local-first live codebase graph and AI context pack generator",
  "author": "vibedev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HoangHieuu/VibeGraph.git"
  },
  "homepage": "https://github.com/HoangHieuu/VibeGraph#readme",
  "bugs": {
    "url": "https://github.com/HoangHieuu/VibeGraph/issues"
  },
  "keywords": [
    "codebase-graph",
    "dependency-graph",
    "developer-tools",
    "ai-context",
    "local-first"
  ],
  "type": "module",
  "bin": {
    "vibegraph": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/clean.mjs && tsc -p tsconfig.build.json && node scripts/prepare-runtime.mjs",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run src"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.14"
  }
}
